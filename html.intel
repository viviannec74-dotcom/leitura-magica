<footer>
  <p><strong>Leitura Mágica</strong> — Material de apoio educacional</p>
  <p style="margin-top:8px;">Este produto é um material de apoio e não substitui acompanhamento de fonoaudiólogo, psicopedagogo ou profissional de saúde.</p>
  <p style="margin-top:8px;">© 2025 · Todos os direitos reservados</p>
</footer>

<script>
function toggleFaq(el){
  const item=el.parentElement;
  item.classList.toggle('open');
}
// Smooth scroll
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{
    e.preventDefault();
    const t=document.querySelector(a.getAttribute('href'));
    if(t)t.scrollIntoView({behavior:'smooth'});
  });
});
// Animate on scroll
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){e.target.style.opacity='1';e.target.style.transform='translateY(0)';}
  });
},{threshold:0.1});
document.querySelectorAll('.ben-card,.incl-item,.dor-card,.dep-card,.pq-card').forEach(el=>{
  el.style.opacity='0';el.style.transform='translateY(20px)';
  el.style.transition='opacity .5s ease, transform .5s ease';
  obs.observe(el);
});
</script>
</body>
</html>
